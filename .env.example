# Sunucu portu (opsiyonel, varsayılan 3000)
PORT=3000

# JWT imzalama anahtarı - üretimde mutlaka uzun ve rastgele bir değerle değiştirin
JWT_SECRET=

# E-posta doğrulaması: 'off' ise kayıt kod adımı olmadan doğrudan tamamlanır.
# Boş/açık bırakılır ve SMTP doluysa doğrulama kodu e-postayla gönderilir.
EMAIL_VERIFICATION=off

# SMTP - Üniversite mail sunucusu bilgileri (mail.aybu.edu.tr ayar sayfasından)
SMTP_HOST=mail.aybu.edu.tr
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Akademik Ödül Sistemi <KENDI_KULLANICI_ADINIZ@aybu.edu.tr>"
